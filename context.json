  "prefix_patterns": [
    {
      "style": "icon_label_separator",
      "description": "Primary prefix pattern: colored icon + white uppercase label + dark_gray separator",
      "format": "<color:ICON_COLOR>ICON</color> <white>LABEL <dark_gray>▪ <white>message",
      "examples": [
        "<color:#ffc885>⛃</color> <white>ᴍᴏɴᴇʏ <dark_gray>▪",
        "<color:#52ffc2>⏩</color> <white>ᴅịᴄʜ ᴄʜᴜʏểɴ <dark_gray>▪",
        "<color:#cec2ff>⌂</color> <white>ʜᴏᴍᴇ <dark_gray>▪",
        "<color:#99ff94>✔</color> <white>ᴛʜàɴʜ ᴄôɴɢ <dark_gray>▪"
      ]
    },
    {
      "style": "gradient_bracket",
      "description": "Gradient bracketed prefix for informational/generic messages",
      "format": "<gradient:#COLOR1:#COLOR2>[ICON TEXT]</gradient>",
      "examples": [
        "<gradient:#ffb469:#ffdb9c>[⌚ ᴛʜờɪ ɢɪᴀɴ đã ᴄʜơɪ {0}]</gradient>",
        "<gradient:#ffb469:#ffdb9c>[⚐ ᴋʜᴏảɴɢ ᴄáᴄʜ {0}]</gradient>",
        "<gradient:#adffbf:#fff2ed>[👥 ᴛʜôɴɢ ʙáᴏ]</gradient>"
      ]
    },
    {
      "style": "gradient_error",
      "description": "Full gradient wrap for error and warning messages (no icon prefix)",
      "format": "<gradient:#ff7817:#ffc46b>error message text.</gradient>",
      "examples": [
        "<gradient:#ff7817:#ffc46b>ʙạɴ ᴋʜôɴɢ ᴄó qᴜʏềɴ để ᴅùɴɢ ʟệɴʜ ɴàʏ.</gradient>"
      ]
    }
  ],
  "layout_patterns": [
    {
      "name": "standard_message",
      "description": "Most common layout: icon + label + separator + message body",
      "structure": "ICON LABEL ▪ message text",
      "format": "<color:X>ICON</color> <white>LABEL <dark_gray>▪ <white>message text",
      "usage": "Used for 80%+ of all functional messages"
    },
    {
      "name": "success_message",
      "description": "Success messages use the ✔ icon with 'ᴛʜàɴʜ ᴄôɴɢ' (success) label",
      "structure": "✔ ᴛʜàɴʜ ᴄôɴɢ ▪ message text",
      "format": "<color:#99ff94>✔</color> <white>ᴛʜàɴʜ ᴄôɴɢ <dark_gray>▪ <white>message text"
    },
    {
      "name": "error_message",
      "description": "Error messages use a full gradient wrap with no icon prefix",
      "structure": "gradient-wrapped error text",
      "format": "<gradient:#ff7817:#ffc46b>error text</gradient>"
    },
    {
      "name": "error_with_icon",
      "description": "Named error format with ✖ icon",
      "structure": "✖ ʟỗɪ ▪ message text",
      "format": "<color:#ff7817>✖ ʟỗɪ <dark_gray>▪ <gradient:#ff7817:#ffc46b>{0}</gradient>"
    },
    {
      "name": "notification_block",
      "description": "Multi-line notification blocks for important events (ban, mute, jail, mail)",
      "structure": "\\n gradient_header \\n\\n  type_line \\n   detail_lines \\n",
      "format": "\\n<gradient:#ffbaf4:#7dfdff>HEADER</gradient>\\n\\n  <white>ʟᴏạɪ: <color:#e2ffc7>ICON TYPE</color>\\n   <color:#e2d1ff>ICON </color><white>FIELD: <color:#e2d1ff>VALUE</color>\\n",
      "field_colors": {
        "type": "#e2ffc7",
        "player": "#e2d1ff",
        "action_by": "#bcffa3",
        "reason": "#faffbf",
        "expiry": "#bcffa3"
      },
      "field_icons": {
        "player": "👤",
        "action_by": "🪓",
        "reason": "✎",
        "expiry": "⌛",
        "info": "ℹ"
      }
    },
    {
      "name": "list_display",
      "description": "Lists use the category icon + label + colon, then items on next line with ▪ separator",
      "structure": "ICON LABEL: \\n ▪ [items]",
      "format": "<color:X>ICON</color> <white>LABEL: \\n <dark_gray>▪ <color:X>[{0}]</color>"
    },
    {
      "name": "hover_click_interactive",
      "description": "Interactive messages with hover tooltips and click actions",
      "structure": "<hover><click>visible text</click></hover>",
      "tooltip_format": "<color:#fff48c>ℹ</color> <white>ᴍô ᴛả\\n <color:#fff48c>ᴄʟɪᴄᴋ</color><white> để ACTION"
    },
    {
      "name": "page_separator",
      "description": "Page headers use gradient strikethrough separators",
      "format": "<gradient:#fff2ed:#adffbf><st>────</st></gradient> <color:#adffbf>TITLE</color> <st>─</st> <white>ᴛʀᴀɴɢ <color:#adffbf>{0}</color><white>/<color:#adffbf>{1}</color> <gradient:#adffbf:#fff2ed><st>────</st></gradient>"
    }
  ],
  "formatting_rules": {
    "text_style": {
      "description": "All text uses Unicode small caps (ᴀʙᴄᴅᴇғ...) instead of regular characters",
      "applies_to": "All visible player-facing text content",
      "example": "ᴛʜàɴʜ ᴄôɴɢ instead of THÀNH CÔNG"
    },
    "separator_character": {
      "character": "▪",
      "color": "dark_gray",
      "usage": "Always placed between the label and the message content with spaces"
    },
    "highlight_variables": {
      "description": "Variable/dynamic values are highlighted using the category's accent color",
      "format": "<color:ACCENT>{variable}</color>",
      "example": "message text <color:#ffc885>{0}</color><white> rest of message"
    },
    "color_reset": {
      "description": "After colored variables, white is re-applied for continuing text",
      "format": "<color:X>{0}</color><white>continuing text"
    },
    "error_pattern": {
      "description": "All errors and warnings use the same gradient without icons",
      "gradient": "<gradient:#ff7817:#ffc46b>",
      "no_prefix": true
    },
    "success_pattern": {
      "description": "All success messages start with green ✔ followed by white 'ᴛʜàɴʜ ᴄôɴɢ'",
      "icon": "✔",
      "icon_color": "#99ff94",
      "label": "ᴛʜàɴʜ ᴄôɴɢ"
    },
    "newline_escaping": {
      "description": "Line breaks in messages use \\\\n (escaped newline) for multiline content",
      "example": "line one\\nline two"
    },
    "exclamation_escaping": {
      "description": "Exclamation marks are escaped with backslash in .properties format",
      "example": "\\!"
    },
    "gradient_usage": {
